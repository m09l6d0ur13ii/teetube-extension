{
  "manifest_version": 3,
  "name": "TeeTube",
  "version": "1.0",
  "description": "View TeeTube tags directly on YouTube and tracking websites.",
  "permissions": [
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_title": "Open TeeTube Website",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*", 
        "*://*.ddnet.org/*", "*://ddnet.org/*",
        "*://*.ddstats.tw/*", "*://ddstats.tw/*",
        "*://*.teerank.io/*", "*://teerank.io/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
